# ============================================================
#  PORTFOLIO MONOREPO — .gitignore
#  Covers: Vite/React (web), Python/FastAPI (api), Node packages
# ============================================================

# ─── Secrets & Environment ──────────────────────────────────
.env
.env.*
!.env.example          # keep the example template
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ─── Python (apps/api) ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
ENV/
.Python
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ─── Node / JS / TS (apps/web, packages/*) ──────────────────
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ─── Build outputs ──────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.output/
.vercel/
.netlify/

# ─── Vite ───────────────────────────────────────────────────
*.local
vite.config.ts.timestamp-*

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo

# ─── OS & Editor ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# JetBrains IDEs
.idea/

# VS Code (keep shared settings if you want — adjust as needed)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─── Misc ───────────────────────────────────────────────────
.cache/
.turbo/
.swc/
*.swp
*.swo
.tmp/
tmp/
# Note: __pycache__/ and *.py[cod] above already cover ALL .pyc/.pyo/.pyd files
